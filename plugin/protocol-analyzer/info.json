{
  "id": "protocol-analyzer",
  "type": "plugin",
  "title": "Protocol Analyzer",
  "description": "Frame capture with hex dumps, decoded field tables, live frame-rate graph, inter-frame timing, auto-scroll toggle, copy-to-clipboard, and auto-reconnect.",
  "author": "Alex Spataru",
  "version": "0.0.1",
  "license": "MIT",
  "category": "Debugging",
  "screenshot": "screenshot.png",
  "entry": "analyzer.py",
  "runtime": "python3",
  "terminal": false,
  "dependencies": [
    {
      "name": "Python 3",
      "executables": ["python3", "python"],
      "url": "https://www.python.org/downloads/"
    }
  ],
  "files": [
    "info.json",
    "analyzer.py",
    "icon.svg"
  ],
  "platforms": {
    "darwin/*": {
      "entry": "run.sh",
      "runtime": "",
      "files": [
        "run.sh"
      ]
    },
    "linux/*": {
      "entry": "run.sh",
      "runtime": "",
      "files": [
        "run.sh"
      ]
    },
    "windows/*": {
      "entry": "run.cmd",
      "runtime": "",
      "files": [
        "run.cmd"
      ]
    }
  },
  "icon": "icon.svg"
}